# PostgreSQL
DATABASE_URL=postgresql+psycopg2://nothard_user:PASSWORD@127.0.0.1/nothard

# JWT signing secret (random, keep private)
JWT_SECRET=change-me

# Frontend origin (used for Telegram OIDC redirects back to the app)
FRONTEND_BASE_URL=https://nothard.uz
DEFAULT_LOCALE=ru
CORS_ORIGINS=https://nothard.uz,http://localhost:3000

# Telegram bot — Mini App initData validation + deep-link account linking
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=notharduzbot

# Telegram Login via OpenID Connect (BotFather → Mini App → Web Login).
# Register allowed URLs and copy the Client ID/Secret here to enable
# "Continue with Telegram" web sign-in. Leave blank to disable (Mini App
# login and deep-link linking still work with just the bot token).
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URI=https://nothard.uz/api/auth/telegram/callback
